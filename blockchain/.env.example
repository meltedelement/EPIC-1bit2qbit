# Sepolia RPC endpoint — get a free key from https://alchemy.com or https://infura.io
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Private key of the deployer wallet (no 0x prefix required by Hardhat)
PRIVATE_KEY=your_private_key_here

# Etherscan API key — used by `npx hardhat verify` to publish contract source
# Get a free key from https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Populated automatically after running scripts/deploy.js — add manually if redeploying
CONTRACT_ADDRESS=
