# Sepolia RPC endpoint — get a free key from https://alchemy.com or https://infura.io
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Private key of the wallet used to sign batcher transactions (no 0x prefix required)
PRIVATE_KEY=your_private_key_here

# Deployed MessageIntegrity contract address on Sepolia — populate after running blockchain/scripts/deploy.js
CONTRACT_ADDRESS=
