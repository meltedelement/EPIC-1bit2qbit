# Sepolia RPC endpoint — get a free key from https://alchemy.com or https://infura.io
VITE_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Deployed MessageIntegrity contract address on Sepolia — populate after running blockchain/scripts/deploy.js
VITE_CONTRACT_ADDRESS=

# Block number the contract was deployed at — used to scope event queries and avoid scanning the full chain
VITE_DEPLOY_BLOCK=
